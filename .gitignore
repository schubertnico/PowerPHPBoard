psalm-baseline.xml
.phpbench.local.json

# ---------- Tests / Coverage / Reports ----------
/coverage/
coverage.xml
clover.xml
junit.xml
testdox.txt
testdox.html
/build/
/dist/
/reports/
infection.log
infection.html
infection.log.txt
infection-summary.log
infection-log.txt
/infection-cache/

# ---------- Setup-Skripte (Security-Risk - sollen nicht auf Live) ----------
create-admin.php
/install.php

