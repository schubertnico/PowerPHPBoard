# =====================================================================
#  PowerPHPBoard - .gitignore
# ---------------------------------------------------------------------
#  Ausschluesse vom Repository. Fuer Deploy-Ausschluesse (was nicht auf
#  den Live-Server darf, aber im Repo bleiben soll) siehe .gitattributes
#  (`export-ignore`) und README "Deployment".
# =====================================================================

# ---------- Dependencies ----------
/vendor/
node_modules/

# ---------- Konfiguration mit Geheimnissen ----------
# WICHTIG: config.inc.php ist historisch getrackt (Template-Werte).
# Eine lokale Kopie fuer echte Zugangsdaten heisst typischerweise:
config.inc.local.php
config.local.php
config.inc.production.php
config.production.php
*.env
.env
.env.local
.env.*.local
.env.production
secrets.php
*.secret
*.pem
*.key
*.p12
*.pfx
auth.json

# ---------- IDE & Editor ----------
/.idea/
/.vscode/
/.vs/
/.fleet/
/nbproject/
*.iml
*.ipr
*.iws
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.buildpath
.settings/
*.code-workspace

# ---------- Logs & Runtime-Artefakte ----------
*.log
/logs/*
!/logs/.gitkeep
/tmp/
/var/
/cache/
/sessions/

# ---------- OS-Artefakte ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
nul

# ---------- PHP / Composer / Analyse-Tools ----------
composer.phar
auth.json
# composer.lock: BLEIBT im Repo (reproduzierbare Installation)
*.phar
*.cache
/.phpunit.cache/
/.psalm-cache/
/.psalm/
/.php-cs-fixer.cache
/.phpstan.cache/
/.phpunit.result.cache
.phpunit.result.cache
/.rector-cache/
