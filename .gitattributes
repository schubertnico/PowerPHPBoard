# =====================================================================
#  PowerPHPBoard - .gitattributes
# ---------------------------------------------------------------------
#  `export-ignore` steuert, welche Dateien beim `git archive` (z. B.
#  Release-ZIPs oder Deploy-Pakete) NICHT mitkopiert werden. Diese
#  Dateien bleiben im Repo, landen aber nicht auf dem Live-Server, wenn
#  das Deployment via `git archive` oder vergleichbare Tools erfolgt.
#
#  Beispiel fuer einen Deploy-Tarball:
#    git archive --format=tar.gz --prefix=powerphpboard/ HEAD > deploy.tar.gz
# =====================================================================

# ---------- Line endings ----------
* text=auto
*.php text eol=lf
*.inc text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf

# Binaere Dateien
*.gif binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
*.zip binary

# =====================================================================
#  Export-Ignore: Nicht auf Live-Server
# =====================================================================

# Git / VCS
.gitignore          export-ignore
.gitattributes      export-ignore
.git/               export-ignore

# CI / CD
.github/            export-ignore

# Docker Dev-Stack (kommt nicht auf Live)
.docker/            export-ignore
docker-compose.*.yml export-ignore
Dockerfile*         export-ignore

# Dokumentation / TODOs / Interne Notizen
/docs/              export-ignore
/todos/             export-ignore
CONTRIBUTING.md     export-ignore
SECURITY.md         export-ignore
INSTALLATION.md     export-ignore

# Tests
/tests/             export-ignore
phpunit.xml         export-ignore
phpunit.xml.dist    export-ignore

# Statische Analyse / Code-Qualitaet
phpstan.neon        export-ignore
phpstan-baseline.neon export-ignore
psalm.xml           export-ignore
psalm.xml.dist      export-ignore
phpmd.xml           export-ignore
rector.php          export-ignore
infection.json5     export-ignore
.php-cs-fixer.php   export-ignore
.php-cs-fixer.dist.php export-ignore

# Composer-Dev-Kram bleibt im Repo, aber kommt nicht auf Live.
# composer.json + composer.lock werden fuer `composer install --no-dev`
# aber auf dem Live-Server BENOETIGT - NICHT ausschliessen!

# Setup-Skripte (sollten nur einmalig lokal laufen)
create-admin.php    export-ignore
install_bugfix_*.sql export-ignore
# Hinweis: install.sql wird oft fuer die Erst-Installation gebraucht,
# bleibt daher absichtlich NICHT ausgeschlossen.

# IDE-Configs (falls doch mal eine versehentlich getrackt wird)
.idea/              export-ignore
.vscode/            export-ignore

# Verschiedenes
README.html         export-ignore
