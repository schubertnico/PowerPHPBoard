{
    "name": "powerscripts/powerphpboard",
    "description": "PowerPHPBoard - A simple PHP forum system",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Nico Schubert",
            "email": "info@powerscripts.org"
        }
    ],
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PowerPHPBoard\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PowerPHPBoard\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=512M",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4"
        }
    }
}
